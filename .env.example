# LLM Gateway Configuration
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Admin API key (used to manage user API keys)
ADMIN_API_KEY=changeme

# Provider: Ollama
OLLAMA_URL=http://host.docker.internal:11434

# Provider: Claude Proxy (Anthropic Messages API)
CLAUDE_PROXY_URL=http://host.docker.internal:9789

# Provider: OpenRouter
OPENROUTER_API_KEY=

# Provider: MiniMax
MINIMAX_API_KEY=

# Database
DB_PATH=./data/gateway.db
